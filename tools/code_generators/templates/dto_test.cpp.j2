#include <optional>
#include "common/helpers/time_helpers.h"

using namespace dto;

BOOST_AUTO_TEST_SUITE({{ dto.name }}Tests)

// Тест: Конструктор по умолчанию
BOOST_AUTO_TEST_CASE(DefaultConstructor)
{
    {{ dto.name }} dto;

    // Все optional поля должны быть пустыми
    {% for field in dto.fields %}
    {% if not field.const_value %}
    BOOST_TEST(!dto.has{{ field.name_pascal }}());
    {% endif %}
    {% endfor %}
}

// Тест: Геттеры и сеттеры
BOOST_AUTO_TEST_CASE(GettersAndSetters)
{
    {{ dto.name }} dto;

    {% for field in dto.fields %}
    // Проверка поля: {{ field.name_camel }}
    {
        {% if not field.const_value %}
        BOOST_TEST(!dto.has{{ field.name_pascal }}());

        {{ field.cpp_type }} testValue = 
        {%- if field.cpp_type == 'bool' -%}
            true
        {%- elif field.cpp_type in ['int64_t', 'int32_t'] -%}
            42
        {%- elif field.cpp_type in ['double', 'float'] -%}
            3.14
        {%- elif field.cpp_type == 'std::string' -%}
            "test_value"
        {%- elif field.cpp_type == 'std::chrono::system_clock::time_point' -%}
            secondsToTimePoint(1640995200)
        {%- elif field.cpp_type.startswith('std::vector<') -%}
            {"item1", "item2"}
        {%- elif field.cpp_type in dto_names -%}
            {{ field.cpp_type }}()
        {%- else -%}
            {}
        {%- endif -%}
        ;
        dto.set{{ field.name_pascal }}(testValue);

        BOOST_TEST(dto.has{{ field.name_pascal }}());

        {% if field.cpp_type == 'std::chrono::system_clock::time_point' %}
        BOOST_CHECK_EQUAL(
            timePointToSeconds(dto.{{ field.name_camel }}().value()),
            timePointToSeconds(testValue)
        );
        {% elif field.cpp_type in dto_names %}
        // DTO объекты сравниваем через toJson()
        BOOST_TEST(dto.{{ field.name_camel }}().value().toJson() == testValue.toJson());
        {% else %}
        BOOST_TEST(dto.{{ field.name_camel }}().value() == testValue);
        {% endif %}

        // Проверка clear
        dto.clear{{ field.name_pascal }}();
        BOOST_TEST(!dto.has{{ field.name_pascal }}());
        {% endif %}
    }
    {% endfor %}
}

// Тест: сериализация в JSON
BOOST_AUTO_TEST_CASE(ToJsonSerialization)
{
    {{ dto.name }} dto;

    {% for field in dto.fields %}
    // Поле: {{ field.name_camel }}
    {% if not field.const_value %}
        {% if field.cpp_type == 'std::string' %}
    dto.set{{ field.name_pascal }}("test_{{ field.name_snake }}");
        {% elif field.cpp_type in ['int64_t', 'int32_t'] %}
    dto.set{{ field.name_pascal }}(42);
        {% elif field.cpp_type == 'bool' %}
    dto.set{{ field.name_pascal }}(true);
        {% elif field.cpp_type in ['double', 'float'] %}
    dto.set{{ field.name_pascal }}(3.14);
        {% elif field.cpp_type == 'std::chrono::system_clock::time_point' %}
    dto.set{{ field.name_pascal }}(secondsToTimePoint(1640995200));
        {% elif field.cpp_type.startswith('std::vector<') %}
    dto.set{{ field.name_pascal }}({"item1", "item2"});
        {% elif field.cpp_type in dto_names %}
    dto.set{{ field.name_pascal }}({{ field.cpp_type }}());
    {% endif %}
    {% endif %}
    {% endfor %}

    nlohmann::json json = dto.toJson();

    // Проверка полей JSON
    {% for field in dto.fields %}
    {% if field.const_value %}
    // Константное поле {{ field.name_camel }} должно иметь значение по умолчанию
    BOOST_TEST(json.contains("{{ field.name_snake }}"));
    BOOST_TEST(json["{{ field.name_snake }}"].get<std::string>() == "{{ field.const_value }}");
    {% else %}
        {% if field.cpp_type == 'std::string' %}
    BOOST_TEST(json.contains("{{ field.name_snake }}"));
    BOOST_TEST(json["{{ field.name_snake }}"].get<std::string>() == "test_{{ field.name_snake }}");
        {% elif field.cpp_type in ['int64_t', 'int32_t'] %}
    BOOST_TEST(json.contains("{{ field.name_snake }}"));
    BOOST_TEST(json["{{ field.name_snake }}"].get<int64_t>() == 42);
        {% elif field.cpp_type == 'bool' %}
    BOOST_TEST(json.contains("{{ field.name_snake }}"));
    BOOST_TEST(json["{{ field.name_snake }}"].get<bool>() == true);
        {% elif field.cpp_type in ['double', 'float'] %}
    BOOST_TEST(json.contains("{{ field.name_snake }}"));
    BOOST_CHECK_CLOSE(json["{{ field.name_snake }}"].get<double>(), 3.14, 0.001);
        {% elif field.cpp_type == 'std::chrono::system_clock::time_point' %}
    BOOST_TEST(json.contains("{{ field.name_snake }}"));
    BOOST_TEST(json["{{ field.name_snake }}"].get<int64_t>() == 1640995200);
        {% elif field.cpp_type.startswith('std::vector<') %}
    BOOST_TEST(json.contains("{{ field.name_snake }}"));
    BOOST_TEST(json["{{ field.name_snake }}"].is_array());
    BOOST_TEST(json["{{ field.name_snake }}"].size() == 2);
        {% endif %}
    {% endif %}
    {% endfor %}
}

// Тест: десериализация из JSON
BOOST_AUTO_TEST_CASE(FromJsonDeserialization)
{
    nlohmann::json json = nlohmann::json::object();
    {% for field in dto.fields %}
    {% if not field.const_value %}
        {% if field.cpp_type == 'std::string' %}
    json["{{ field.name_snake }}"] = "test_{{ field.name_snake }}";
        {% elif field.cpp_type in ['int64_t', 'int32_t'] %}
    json["{{ field.name_snake }}"] = 42;
        {% elif field.cpp_type == 'bool' %}
    json["{{ field.name_snake }}"] = true;
        {% elif field.cpp_type in ['double', 'float'] %}
    json["{{ field.name_snake }}"] = 3.14;
        {% elif field.cpp_type == 'std::chrono::system_clock::time_point' %}
    json["{{ field.name_snake }}"] = 1640995200;
        {% elif field.cpp_type.startswith('std::vector<') %}
    json["{{ field.name_snake }}"] = nlohmann::json::array({"item1", "item2"});
        {% elif field.cpp_type in dto_names %}
    json["{{ field.name_snake }}"] = nlohmann::json::object();
        {% endif %}
    {% endif %}
    {% endfor %}

    {{ dto.name }} dto(json);

    // Проверка десериализованных значений
    {% for field in dto.fields %}
    {% if field.const_value %}
    // Константное поле должно иметь значение по умолчанию
    BOOST_TEST(dto.{{ field.name_camel }}() == "{{ field.const_value }}");
    {% else %}
    BOOST_TEST(dto.has{{ field.name_pascal }}());
        {% if field.cpp_type == 'std::string' %}
    BOOST_TEST(dto.{{ field.name_camel }}().value() == "test_{{ field.name_snake }}");
        {% elif field.cpp_type in ['int64_t', 'int32_t'] %}
    BOOST_TEST(dto.{{ field.name_camel }}().value() == 42);
        {% elif field.cpp_type == 'bool' %}
    BOOST_TEST(dto.{{ field.name_camel }}().value() == true);
        {% elif field.cpp_type in ['double', 'float'] %}
    BOOST_CHECK_CLOSE(dto.{{ field.name_camel }}().value(), 3.14, 0.001);
        {% elif field.cpp_type == 'std::chrono::system_clock::time_point' %}
    BOOST_CHECK_EQUAL(timePointToSeconds(dto.{{ field.name_camel }}().value()), 1640995200);
        {% elif field.cpp_type.startswith('std::vector<') %}
    BOOST_TEST(dto.{{ field.name_camel }}().value().size() == 2);
        {% endif %}
    {% endif %}
    {% endfor %}
}

