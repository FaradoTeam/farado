// Тест: проверка isValid
BOOST_AUTO_TEST_CASE(Validation)
{
    {{ dto.name }} dto;

    // Проверяем, есть ли обязательные поля
    {% set ns = namespace(has_required=false) %}
    {% for field in dto.fields %}
        {% if field.required and not field.const_value %}
            {% set ns.has_required = true %}
        {% endif %}
    {% endfor %}

    // Изначально невалиден, если есть обязательные поля
    {% if ns.has_required %}
    BOOST_TEST(!dto.isValid());
    BOOST_TEST(dto.validationError().find("обязательным") != std::string::npos);
    {% else %}
    BOOST_TEST(dto.isValid());
    BOOST_TEST(dto.validationError().empty());
    {% endif %}

    // Заполняем обязательные поля
    {% for field in dto.fields %}
    {% if field.required and not field.const_value %}
        {% if field.cpp_type == 'std::string' %}
    dto.{{ field.name_camel }} = "test_{{ field.name_camel }}";
        {% elif field.cpp_type in ['int64_t', 'int32_t'] %}
    dto.{{ field.name_camel }} = 42;
        {% elif field.cpp_type == 'bool' %}
    dto.{{ field.name_camel }} = true;
        {% elif field.cpp_type in ['double', 'float'] %}
    dto.{{ field.name_camel }} = 3.14;
        {% elif field.cpp_type == 'std::chrono::system_clock::time_point' %}
    dto.{{ field.name_camel }} = secondsToTimePoint(1640995200);
        {% elif field.cpp_type.startswith('std::vector<') %}
    dto.{{ field.name_camel }} = {"item1"};
        {% elif field.cpp_type in dto_names %}
    dto.{{ field.name_camel }} = {{ field.cpp_type }}();
        {% endif %}
    {% endif %}
    {% endfor %}

    // Теперь должен быть валидным
    {% if ns.has_required %}
    BOOST_TEST(dto.isValid());
    BOOST_TEST(dto.validationError().empty());
    {% else %}
    // Если обязательных полей нет, DTO всегда валиден
    BOOST_TEST(dto.isValid());
    {% endif %}
}

// Тест: Операторы сравнения
BOOST_AUTO_TEST_CASE(ComparisonOperators)
{
    {{ dto.name }} dto1;
    {{ dto.name }} dto2;

    // Изначально они должны быть равны (оба пустые)
    BOOST_TEST(dto1 == dto2);
    BOOST_TEST(!(dto1 != dto2));

    {% set ns = namespace(found=false) %}
    {% for field in dto.fields %}
    {% if not field.const_value and field.required and not ns.found %}
        {% set ns.found = true %}
    // Изменим поле {{ field.name_camel }}, чтобы сделать их разными
        {% if field.cpp_type == 'std::string' %}
    dto1.{{ field.name_camel }} = "different_value";
        {% elif field.cpp_type in ['int64_t', 'int32_t'] %}
    dto1.{{ field.name_camel }} = 999;
        {% elif field.cpp_type == 'bool' %}
    dto1.{{ field.name_camel }} = false;
        {% elif field.cpp_type in ['double', 'float'] %}
    dto1.{{ field.name_camel }} = 999.99;
        {% elif field.cpp_type.startswith('std::vector<') %}
    dto1.{{ field.name_camel }} = {"different"};
        {% elif field.cpp_type == 'std::chrono::system_clock::time_point' %}
    dto1.{{ field.name_camel }} = secondsToTimePoint(1735689600);
        {% else %}
    // Для других типов
    dto1.{{ field.name_camel }} = {};
        {% endif %}

    BOOST_TEST(dto1 != dto2);
    BOOST_TEST(!(dto1 == dto2));
    {% endif %}
    {% endfor %}

    {% if not ns.found %}
    // Если нет обязательных полей, используем первое неконстантное поле
    {% for field in dto.fields %}
    {% if not field.const_value and not ns.found %}
        {% set ns.found = true %}
        {% if field.cpp_type == 'std::string' %}
    dto1.{{ field.name_camel }} = "different_value";
        {% elif field.cpp_type in ['int64_t', 'int32_t'] %}
    dto1.{{ field.name_camel }} = 999;
        {% elif field.cpp_type == 'bool' %}
    dto1.{{ field.name_camel }} = true;
        {% elif field.cpp_type in ['double', 'float'] %}
    dto1.{{ field.name_camel }} = 999.99;
        {% elif field.cpp_type.startswith('std::vector<') %}
    dto1.{{ field.name_camel }} = {"different"};
        {% elif field.cpp_type == 'std::chrono::system_clock::time_point' %}
    dto1.{{ field.name_camel }} = secondsToTimePoint(1735689600);
        {% endif %}

    BOOST_TEST(dto1 != dto2);
    BOOST_TEST(!(dto1 == dto2));
    {% endif %}
    {% endfor %}
    {% endif %}
}

