{{ dto.name }}::{{ dto.name }}(const nlohmann::json& json)
{
    fromJson(json);
}

nlohmann::json {{ dto.name }}::toJson() const
{
    nlohmann::json result;

    {% for field in dto.fields %}
    // {{ field.description or field.name }}
    {% if field.const_value %}
    result["{{ field.name_snake }}"] = m_{{ field.name_camel }};
    {% else %}
    if (m_{{ field.name_camel }}.has_value())
    {
        {% if field.cpp_type == 'std::chrono::system_clock::time_point' %}
        result["{{ field.name_snake }}"] = timePointToSeconds(m_{{ field.name_camel }}.value());
        {% elif field.cpp_type.startswith('std::vector<') %}
        if (!m_{{ field.name_camel }}.value().empty())
        {
            nlohmann::json arr = nlohmann::json::array();
            for (const auto& item : m_{{ field.name_camel }}.value())
            {
                {% if field.array_item_type in dto_names %}
                arr.push_back(item.toJson());
                {% else %}
                arr.push_back(item);
                {% endif %}
            }
            result["{{ field.name_snake }}"] = arr;
        }
        {% elif field.cpp_type in dto_names %}
        result["{{ field.name_snake }}"] = m_{{ field.name_camel }}.value().toJson();
        {% elif field.cpp_type == 'nlohmann::json' %}
        if (!m_{{ field.name_camel }}.value().is_null())
        {
            result["{{ field.name_snake }}"] = m_{{ field.name_camel }}.value();
        }
        {% else %}
        result["{{ field.name_snake }}"] = m_{{ field.name_camel }}.value();
        {% endif %}
    }
    {% endif %}
    {% endfor %}

    return result;
}

bool {{ dto.name }}::fromJson(const nlohmann::json& json)
{
    bool success = true;

    {% for field in dto.fields %}
    // {{ field.description or field.name }}
    {% if field.const_value %}
    // Constant field - ignore value from JSON
    {% else %}
    if (json.contains("{{ field.name_snake }}") && !json["{{ field.name_snake }}"].is_null())
    {
        try
        {
            {% if field.cpp_type == 'std::string' %}
            m_{{ field.name_camel }} = json["{{ field.name_snake }}"].get<std::string>();
            {% elif field.cpp_type == 'std::chrono::system_clock::time_point' %}
            auto timestamp = json["{{ field.name_snake }}"].get<int64_t>();
            m_{{ field.name_camel }} = secondsToTimePoint(timestamp);
            {% elif field.cpp_type.startswith('std::vector<') %}
            {{ field.cpp_type }} vec;
            for (const auto& item : json["{{ field.name_snake }}"])
            {
                {% if field.array_item_type in dto_names %}
                vec.push_back({{ field.array_item_type }}(item));
                {% elif field.array_item_type in ['int64_t', 'int32_t', 'double', 'float'] %}
                vec.push_back(item.get<{{ field.array_item_type }}>());
                {% elif field.array_item_type == 'std::string' %}
                vec.push_back(item.get<std::string>());
                {% elif field.array_item_type == 'bool' %}
                vec.push_back(item.get<bool>());
                {% else %}
                vec.push_back(item);
                {% endif %}
            }
            m_{{ field.name_camel }} = std::move(vec);
            {% elif field.cpp_type in dto_names %}
            m_{{ field.name_camel }} = {{ field.cpp_type }}(json["{{ field.name_snake }}"]);
            {% elif field.cpp_type == 'nlohmann::json' %}
            m_{{ field.name_camel }} = json["{{ field.name_snake }}"];
            {% elif field.cpp_type in ['int64_t', 'int32_t', 'double', 'float', 'bool'] %}
            m_{{ field.name_camel }} = json["{{ field.name_snake }}"].get<{{ field.cpp_type }}>();
            {% else %}
            m_{{ field.name_camel }} = json["{{ field.name_snake }}"].get<{{ field.cpp_type }}>();
            {% endif %}
        }
        catch (const std::exception& e)
        {
            success = false;
        }
    }
    else
    {
        m_{{ field.name_camel }} = std::nullopt;
    }
    {% endif %}
    {% endfor %}

    return success;
}

bool {{ dto.name }}::isValid() const
{
    {% for field in dto.fields %}
    {% if field.required and not field.const_value %}
    if (!m_{{ field.name_camel }}.has_value())
    {
        return false;
    }
    {% endif %}
    {% endfor %}

    // Дополнительные проверки для непустых значений
    {% for field in dto.fields %}
    {% if field.required and not field.const_value %}
    {% if field.cpp_type == 'std::string' %}
    if (m_{{ field.name_camel }}.value().empty())
    {
        return false;
    }
    {% elif field.cpp_type.startswith('std::vector<') %}
    if (m_{{ field.name_camel }}.value().empty())
    {
        return false;
    }
    {% endif %}
    {% endif %}
    {% endfor %}

    return true;
}

std::string {{ dto.name }}::validationError() const
{
    {% for field in dto.fields %}
    {% if field.required and not field.const_value %}
    if (!m_{{ field.name_camel }}.has_value())
    {
        return "Поле «{{ field.name_snake }}» является обязательным для заполнения";
    }
    {% endif %}
    {% endfor %}

    {% for field in dto.fields %}
    {% if field.required and not field.const_value %}
    {% if field.cpp_type == 'std::string' %}
    if (m_{{ field.name_camel }}.value().empty())
    {
        return "Поле «{{ field.name_snake }}» не может быть пустой строкой";
    }
    {% elif field.cpp_type.startswith('std::vector<') %}
    if (m_{{ field.name_camel }}.value().empty())
    {
        return "Поле «{{ field.name_snake }}» должно содержать хотя бы один элемент";
    }
    {% endif %}
    {% endif %}
    {% endfor %}

    return "";
}

